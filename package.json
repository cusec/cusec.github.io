{
  "name": "cusec-landing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.33.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10.33.0",
    "npm": ">=999.0.0",
    "yarn": ">=999.0.0"
  },
  "scripts": {
    "preinstall": "node ./scripts/ensure-pnpm.mjs",
    "prepare": "lefthook install",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@visx/group": "4.0.0-alpha.11",
    "@visx/scale": "4.0.0-alpha.11",
    "@visx/shape": "4.0.0-alpha.11",
    "next": "^15.3.1",
    "next-intl": "^4.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "lefthook": "^2.1.9",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
